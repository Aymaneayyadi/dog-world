---
import '../styles/style.css';
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title ? `${title} - Dog World` : 'Dog World - Everything About Dogs'}</title>
  <meta name="description" content={description || 'Expert advice on dog health, food, training, breeds, grooming and more.'}>
  <meta name="monetag" content="4ebb5c8f3a878451e743fe2599688a28">
  <meta name="google-site-verification" content="rjbJuvr6CqGi2OTpaj-ZyBaSYV7Da3o60X5nxawsnys" />
  <script src="https://quge5.com/88/tag.min.js" data-zone="255581" async data-cfasync="false"></script>
</head>
<body>
  <a class="skip-link screen-reader-text" href="#main">Skip to content</a>
  <slot name="header" />
  <main id="main" class="site-content">
    <slot />
  </main>
  <slot name="footer" />
  <script is:inline src="/js/script.js"></script>
</body>
</html>
