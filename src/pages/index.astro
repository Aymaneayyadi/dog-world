---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles
  .map(e => ({ ...e.data, slug: e.slug }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featured = sorted.slice(0, 6);
---

<BaseLayout title="Home" description="Expert advice on dog health, food, training, breeds, grooming and more.">
  <Fragment slot="header">
    <Header currentPage="home" />
    <section class="hero-section">
      <div class="hero-content">
        <h1 data-en="Welcome to Dog World" data-fr="Bienvenue au Monde du Chien" data-ar="مرحبًا بكم في عالم الكلاب">Welcome to Dog World</h1>
        <p data-en="Expert advice on dog health, food, training, breeds, grooming and more." data-fr="Conseils d'experts sur la santé canine, l'alimentation, l'éducation, les races et plus encore." data-ar="نصائح خبراء حول صحة الكلاب والغذاء والتدريب والسلالات والعناية وأكثر.">Expert advice on dog health, food, training, breeds, grooming and more.</p>
      </div>
    </section>
  </Fragment>

  <div class="content-area">
    <div class="main-content">
      <section class="featured-posts">
        <h2 data-en="Latest Articles" data-fr="Derniers Articles" data-ar="أحدث المقالات">Latest Articles</h2>
        {featured.length > 0 ? (
          <div class="posts-grid">
            {featured.map(post => <PostCard {...post} />)}
          </div>
        ) : (
          <div class="no-results">
            <h2>No articles yet</h2>
            <p>Articles will appear here once published.</p>
          </div>
        )}
      </section>
    </div>
    <aside class="sidebar"></aside>
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
