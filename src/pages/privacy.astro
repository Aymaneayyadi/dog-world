---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdWidget from '../components/AdWidget.astro';
---

<BaseLayout title="Privacy Policy" description="Dog World privacy policy">
  <Fragment slot="header"><Header /></Fragment>

  <div class="page-header">
    <div class="container">
      <h1 data-en="Privacy Policy" data-fr="Politique de Confidentialité" data-ar="سياسة الخصوصية">Privacy Policy</h1>
    </div>
  </div>

  <div class="content-area no-sidebar">
    <div class="page-content">
      <p>Your privacy is important to us. This policy outlines how we collect, use, and protect your information.</p>
      <AdWidget />
      <h2>Information We Collect</h2>
      <p>We collect information you provide when contacting us or subscribing to our newsletter.</p>
      <h2>How We Use Your Information</h2>
      <p>We use your information to respond to inquiries and improve our content.</p>
      <h2>Cookies</h2>
      <p>We may use cookies to enhance your browsing experience.</p>
      <h2>Contact</h2>
      <p>For privacy concerns, please contact us.</p>
    </div>
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
