---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404" description="Page not found">
  <Fragment slot="header"><Header /></Fragment>

  <div class="error-404">
    <h1 data-en="404" data-fr="404" data-ar="٤٠٤">404</h1>
    <p data-en="Page not found." data-fr="Page non trouvée." data-ar="الصفحة غير موجودة.">Page not found.</p>
    <a href="/" class="btn btn-primary" data-en="Go Home" data-fr="Accueil" data-ar="الصفحة الرئيسية">Go Home</a>
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
