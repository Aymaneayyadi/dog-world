---
export interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  slug: string;
  image?: string;
}
const { title, description, date, category, slug, image } = Astro.props;
---

<article class="post-card">
  <div class="post-card-thumb">
    <a href={`/articles/${slug}`}>
      {image ? (
        <img src={image} alt={title} />
      ) : (
        <div style={`background:linear-gradient(135deg,var(--secondary),var(--primary));min-height:180px;`}></div>
      )}
    </a>
    <span class="post-card-cat"><a href={`/category/${category.toLowerCase()}`}>{category}</a></span>
  </div>
  <div class="post-card-body">
    <h3><a href={`/articles/${slug}`}>{title}</a></h3>
    <div class="post-card-meta">{date}</div>
    <div class="post-card-excerpt"><p>{description}</p></div>
  </div>
</article>
